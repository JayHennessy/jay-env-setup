{{- $git_name := promptStringOnce . "git_name" "Git full name" -}}
{{- $git_email := promptStringOnce . "git_email" "Git email address" -}}
{{- $github_username := promptStringOnce . "github_username" "GitHub username" -}}

[data]
    git_name = {{ $git_name | quote }}
    git_email = {{ $git_email | quote }}
    github_username = {{ $github_username | quote }}
