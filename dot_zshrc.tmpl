# ~/.zshrc - managed by chezmoi

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Path
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/go/bin:$PATH"

# oh-my-zsh
if [ -d "$HOME/.oh-my-zsh" ]; then
    export ZSH="$HOME/.oh-my-zsh"
    ZSH_THEME="robbyrussell"
    plugins=(git extract copypath copyfile zsh-autosuggestions zsh-syntax-highlighting)
    source "$ZSH/oh-my-zsh.sh"
fi

# History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=20000
setopt appendhistory
setopt hist_ignore_dups
setopt hist_ignore_space

# mise
if command -v mise &>/dev/null; then
    eval "$(mise activate zsh)"
fi

# fzf
if command -v fzf &>/dev/null; then
    eval "$(fzf --zsh)"
fi

# zoxide
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh)"
fi

# Aliases
if command -v nvim &>/dev/null; then
    alias vim='nvim'
    alias vi='nvim'
    export EDITOR='nvim'
    export VISUAL='nvim'
fi

if command -v lazygit &>/dev/null; then
    alias lg='lazygit'
fi

if command -v lazydocker &>/dev/null; then
    alias ld='lazydocker'
fi

if command -v k9s &>/dev/null; then
    alias k='k9s'
fi

if command -v lazyworktree &>/dev/null; then
    alias lw='lazyworktree'
fi

if command -v yazi &>/dev/null; then
    alias y='yazi'
fi

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# yy - yazi with directory change on exit
yy() {
    local tmp
    tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd" || return
    fi
    rm -f -- "$tmp"
}

# Source local overrides (not managed by chezmoi)
if [ -f "$HOME/.zshrc.local" ]; then
    . "$HOME/.zshrc.local"
fi
